# Email Notification Configuration
# Copy this file to .env.local and fill in your actual values

# Email Service Settings (Gmail, SendGrid, Mailgun, etc.)
EMAIL_SERVICE=gmail

# Email sender credentials
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Admin email address (receives form submission notifications)
ADMIN_EMAIL=admin@excelhope.org

# Support phone number (displayed in confirmation emails)
SUPPORT_PHONE=+91-XXXXX-XXXXX

# Base URL for your application (used for email links)
BASE_URL=http://localhost:3000

# Google Sheets Configuration (existing)
GOOGLE_SHEETS_TYPE=service_account
GOOGLE_SHEETS_PROJECT_ID=your-project-id
GOOGLE_SHEETS_PRIVATE_KEY_ID=your-key-id
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\nHere\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SHEETS_CLIENT_ID=your-client-id
GOOGLE_SHEETS_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
